{
  "name": "learning-resources-app",
  "version": "1.1.0",
  "private": false,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=7.24.2"
  },
  "scripts": {
    "build": "fec build",
    "build-storybook": "storybook build",
    "cypress": "cypress",
    "cypress:component": "cypress run --component",
    "cypress:open": "cypress open",
    "deploy": "npm-run-all build lint test",
    "lint": "npm-run-all lint:*",
    "lint:js": "eslint src --ignore-pattern '!.storybook' '.storybook/**/*.{ts,tsx}'",
    "lint:js:fix": "eslint src --ignore-pattern '!.storybook' '.storybook/**/*.{ts,tsx}' --fix",
    "patch:hosts": "fec patch-etc-hosts",
    "start": "fec dev-proxy",
    "static": "fec static",
    "storybook": "storybook dev -p 6006",
    "test": "jest --passWithNoTests",
    "test-storybook": "test-storybook --excludeTags test-skip",
    "test-storybook:ci": "test-storybook --ci --excludeTags test-skip",
    "verify": "npm-run-all build lint test",
    "postinstall": "ts-patch install"
  },
  "dependencies": {
    "@data-driven-forms/pf4-component-mapper": "^4.1.4",
    "@data-driven-forms/react-form-renderer": "^4.1.4",
    "@monaco-editor/react": "^4.7.0",
    "@patternfly/quickstarts": "^6.4.0",
    "@patternfly/react-core": "^6.4.0",
    "@patternfly/react-table": "^6.4.0",
    "@redhat-cloud-services/frontend-components": "^6.1.1",
    "@redhat-cloud-services/frontend-components-utilities": "^6.1.1",
    "@redhat-cloud-services/types": "^2.0.3",
    "@scalprum/core": "^0.9.0",
    "@scalprum/react-core": "^0.11.1",
    "@unleash/proxy-client-react": "^4.5.2",
    "axios": "^1.13.2",
    "classnames": "^2.5.1",
    "fuse.js": "^7.1.0",
    "monaco-editor": "^0.55.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-intl": "^6.6.2",
    "react-router-dom": "^6.30.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@patternfly/patternfly": "^6.4.0",
    "@playwright/test": "^1.56.1",
    "@redhat-cloud-services/eslint-config-redhat-cloud-services": "^2.0.12",
    "@redhat-cloud-services/frontend-components-config": "^6.7.4",
    "@redhat-cloud-services/tsc-transform-imports": "^1.0.26",
    "@storybook/addon-docs": "^9.1.19",
    "@storybook/addon-webpack5-compiler-swc": "^3.0.0",
    "@storybook/react-webpack5": "^9.1.19",
    "@storybook/test-runner": "^0.23.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^14.3.1",
    "@types/react": "18.3.27",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "css-loader": "^7.1.4",
    "cypress": "^14.5.4",
    "eslint": "8.57.1",
    "eslint-plugin-storybook": "^9.1.19",
    "identity-obj-proxy": "3.0.0",
    "jest": "29.7.0",
    "jest_workaround": "^0.79.19",
    "jest-environment-jsdom": "^29.7.0",
    "msw": "^2.12.10",
    "msw-storybook-addon": "^2.0.6",
    "npm-run-all2": "5.0.2",
    "remark-gfm": "^4.0.1",
    "sass": "^1.97.3",
    "sass-loader": "^16.0.7",
    "storybook": "^9.1.19",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.5",
    "ts-patch": "^3.3.0",
    "typescript": "^5.9.3",
    "uuid": "^9.0.1",
    "webpack-bundle-analyzer": "4.10.2"
  },
  "insights": {
    "appname": "learning-resources"
  },
  "msw": {
    "workerDirectory": [
      "static"
    ]
  }
}
